PORT=3001
AWS_REGION=eu-north-1

# AWS credentials (DynamoDB + S3 access)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB table names
INGREDIENTS_TABLE=ta-ingredients-dev
RECIPES_TABLE=ta-recipes-dev
SETTINGS_TABLE=ta-settings-dev
EVENTS_TABLE=ta-events-dev
GROCERY_LISTS_TABLE=ta-grocery-lists-dev

# Uncomment for DynamoDB Local during development:
# DDB_ENDPOINT=http://localhost:8000

# S3 bucket for recipe photo uploads
S3_BUCKET=la-table-amelie-uploads-dev

# Admin authentication
# Generate password hashes with: node -e "const b=require('bcryptjs');b.hash('your-password',12).then(console.log)"
ADMIN_CREDENTIALS=[{"email":"admin@example.com","hash":"<bcrypt-hash>"}]
JWT_SECRET=<generate-with-openssl-rand-hex-32>
